# ══════════════════════════════════════════════════════════════════════════════
# .env.example — Copy to .env and fill in your values
# ══════════════════════════════════════════════════════════════════════════════

# ── Ultravox (AI Voice) ──────────────────────────────────────────────────────
# Get from: https://app.ultravox.ai/ → API Keys
ULTRAVOX_API_KEY=your_ultravox_api_key_here
ULTRAVOX_VOICE=Mark
ULTRAVOX_LANGUAGE_HINT=en-IN
# Optional: HMAC secret for verifying Ultravox event webhooks
ULTRAVOX_WEBHOOK_SECRET=

# ── OpenAI (Post-call sentiment analysis) ───────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Sarvam AI (optional — legacy STT/TTS, kept for future use) ───────────────
# Get from: https://app.sarvam.ai/
SARVAM_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Cal.com (Booking) ────────────────────────────────────────────────────────
# Get from: https://app.cal.com/settings/developer/api-keys
CAL_API_KEY=cal_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CAL_EVENT_TYPE_ID=1234567

# ── Supabase (Database) ──────────────────────────────────────────────────────
# Get from: https://app.supabase.com/ → your project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ── Telegram Notifications ───────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram, then get your Chat ID
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# ── VoBiz (SIP Telephony) ────────────────────────────────────────────────────
VOBIZ_SIP_DOMAIN=your_sip_domain.sip.vobiz.ai
VOBIZ_USERNAME=your_username
VOBIZ_PASSWORD=your_password
VOBIZ_OUTBOUND_NUMBER=+91XXXXXXXXXX
# Optional: shared secret VoBiz sends in webhook headers for auth
VOBIZ_WEBHOOK_SECRET=

# ── Call Transfer ─────────────────────────────────────────────────────────────
# Phone number to transfer calls to (human agent fallback)
DEFAULT_TRANSFER_NUMBER=+91XXXXXXXXXX

# ── Server ────────────────────────────────────────────────────────────────────
# Public base URL of this server (used for Ultravox to call back tool endpoints)
SERVER_BASE_URL=https://your-server.com
PORT=8000

# ── n8n (optional workflow automation) ──────────────────────────────────────
N8N_WEBHOOK_URL=

# ── Sentry (optional error tracking) ─────────────────────────────────────────
SENTRY_DSN=
ENVIRONMENT=production
